# ---------------------------------------------------------------------------
# Martin's Tavern — environment variables
# Copy this file to ".env.local" on the server and fill in real values.
# .env.local is gitignored, so secrets never reach the repository.
# ---------------------------------------------------------------------------

# PostgreSQL connection used by the site kill-switch (lib/site-lock.ts).
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://martins_user:CHANGE_ME@localhost:5432/martinstavern

# Set to "true" only if your Postgres requires SSL (a local DB usually does not).
PGSSL=false

# Anti-copy guard is ON by default. Set to "false" to disable it.
NEXT_PUBLIC_COPY_GUARD=true
